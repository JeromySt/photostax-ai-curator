<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhotostaxAiCurator.App.ViewModels"
             x:Class="PhotostaxAiCurator.App.Views.ReviewPage"
             x:DataType="vm:ReviewViewModel"
             Title="Review Queue">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="15">

        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Spacing="15">
            <Label Text="{Binding QueueCount, StringFormat='{0} items to review'}"
                   FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            <Label Text="{Binding CurrentIndex, StringFormat='Reviewing #{0}'}"
                   FontSize="14" TextColor="Gray" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Current Review Item -->
        <ScrollView Grid.Row="1" IsVisible="{Binding HasCurrentItem}">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">

                <!-- Left: Images -->
                <VerticalStackLayout Grid.Column="0" Spacing="10">
                    <Border Padding="5" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent">
                        <Image Source="{Binding FrontImageSource}" HeightRequest="300" Aspect="AspectFit" />
                    </Border>
                    <Border Padding="5" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent" IsVisible="{Binding HasBackImage}">
                        <VerticalStackLayout>
                            <Label Text="📝 Back of Photo" FontAttributes="Bold" FontSize="12" />
                            <Image Source="{Binding BackImageSource}" HeightRequest="200" Aspect="AspectFit" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Right: AI Suggestions (editable) -->
                <ScrollView Grid.Column="1">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="🤖 AI Suggestions" FontSize="18" FontAttributes="Bold" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Title" FontSize="12" FontAttributes="Bold" />
                            <Entry Text="{Binding EditableTitle}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Description" FontSize="12" FontAttributes="Bold" />
                            <Editor Text="{Binding EditableDescription}" HeightRequest="80" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Date" FontSize="12" FontAttributes="Bold" />
                            <Entry Text="{Binding EditableDate}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="People (comma-separated)" FontSize="12" FontAttributes="Bold" />
                            <Entry Text="{Binding EditablePeople}" Placeholder="e.g., John, Jane, Bob" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Places" FontSize="12" FontAttributes="Bold" />
                            <Entry Text="{Binding EditablePlaces}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Events" FontSize="12" FontAttributes="Bold" />
                            <Entry Text="{Binding EditableEvents}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="OCR (Back)" FontSize="12" FontAttributes="Bold" />
                            <Editor Text="{Binding EditableOcrBack}" HeightRequest="60" IsReadOnly="True" />
                        </VerticalStackLayout>

                        <!-- Confidence Indicator -->
                        <Border Padding="10" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent" BackgroundColor="{Binding ConfidenceBadgeColor}">
                            <Label Text="{Binding ConfidenceText}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
                        </Border>

                        <!-- Review Reason -->
                        <Label Text="{Binding ReviewReason}" FontSize="12" TextColor="Gray"
                               IsVisible="{Binding HasReviewReason}" FontAttributes="Italic" />
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </ScrollView>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding IsQueueEmpty}"
                            HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
            <Label Text="✅" FontSize="48" HorizontalOptions="Center" />
            <Label Text="All caught up!" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="No items need review" FontSize="14" TextColor="Gray" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10" IsVisible="{Binding HasCurrentItem}">
            <Button Grid.Column="0" Text="⏭ Skip"
                    Command="{Binding SkipCommand}"
                    BackgroundColor="#757575" TextColor="White" CornerRadius="8" />
            <Button Grid.Column="1" Text="✏️ Edit &amp; Approve"
                    Command="{Binding ApproveWithEditsCommand}"
                    BackgroundColor="#388E3C" TextColor="White" CornerRadius="8" />
            <Button Grid.Column="2" Text="✅ Approve As-Is"
                    Command="{Binding ApproveCommand}"
                    BackgroundColor="#6750A4" TextColor="White" CornerRadius="8" />
        </Grid>
    </Grid>
</ContentPage>