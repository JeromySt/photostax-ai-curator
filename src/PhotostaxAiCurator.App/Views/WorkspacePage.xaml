<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhotostaxAiCurator.App.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PhotostaxAiCurator.App.Views.WorkspacePage"
             x:DataType="vm:WorkspaceViewModel"
             Title="PhotoStax AI Curator">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBool" />
    </ContentPage.Resources>

    <Grid>

        <!-- ═══ Welcome Screen (no folder open) ═══ -->
        <VerticalStackLayout IsVisible="{Binding HasFolderOpen, Converter={StaticResource InvertedBool}}"
                            HorizontalOptions="Center" VerticalOptions="Center" Spacing="20">
            <Label Text="📸" FontSize="64" HorizontalOptions="Center" />
            <Label Text="PhotoStax AI Curator" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="Enhance your scanned photos with AI-powered metadata"
                   FontSize="16" TextColor="Gray" HorizontalOptions="Center" />
            <Button Text="📂  Open Photo Folder"
                    Command="{Binding BrowseFolderCommand}"
                    BackgroundColor="#6750A4" TextColor="White"
                    FontSize="18" CornerRadius="12" Padding="30,15"
                    HorizontalOptions="Center" Margin="0,20,0,0" />
        </VerticalStackLayout>

        <!-- ═══ Workspace (folder open) ═══ -->
        <Grid IsVisible="{Binding HasFolderOpen}" RowDefinitions="Auto,*,Auto">

            <!-- ── Top Bar ── -->
            <Border Grid.Row="0" Padding="15,10" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">
                <Grid ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Label Text="📂" FontSize="16" VerticalOptions="Center" />
                        <Label Text="{Binding FolderPath}" FontSize="14" VerticalOptions="Center"
                               LineBreakMode="MiddleTruncation" MaximumWidthRequest="400" />
                        <Button Text="Change" Command="{Binding BrowseFolderCommand}"
                                FontSize="11" Padding="10,4" CornerRadius="4"
                                BackgroundColor="#E0E0E0" TextColor="#333" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Grid.Column="1" Spacing="20" VerticalOptions="Center">
                        <Label FontSize="13">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding TotalCount}" FontAttributes="Bold" />
                                    <Span Text=" total" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label FontSize="13" TextColor="#1565C0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding AnalyzedCount}" FontAttributes="Bold" />
                                    <Span Text=" analyzed" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label FontSize="13" TextColor="#E65100">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding NeedsReviewCount}" FontAttributes="Bold" />
                                    <Span Text=" review" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label FontSize="13" TextColor="#2E7D32">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding ApprovedCount}" FontAttributes="Bold" />
                                    <Span Text=" approved" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- ── Main Content (3-column) ── -->
            <Grid Grid.Row="1" ColumnDefinitions="200,*,Auto">

                <!-- Left Sidebar -->
                <Border Padding="12" Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#252525}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Actions" FontSize="14" FontAttributes="Bold" Margin="0,4,0,8" />

                        <Button Text="🤖 Analyze All"
                                Command="{Binding AnalyzeAllCommand}"
                                BackgroundColor="#6750A4" TextColor="White" CornerRadius="8" FontSize="13" />
                        <Button Text="✅ Write Approved"
                                Command="{Binding WriteApprovedCommand}"
                                BackgroundColor="#388E3C" TextColor="White" CornerRadius="8" FontSize="13" />
                        <Button Text="⚙️ Settings"
                                Command="{Binding OpenSettingsCommand}"
                                BackgroundColor="#757575" TextColor="White" CornerRadius="8" FontSize="13" />

                        <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

                        <Label Text="Filter" FontSize="14" FontAttributes="Bold" Margin="0,0,0,4" />

                        <Button Text="{Binding TotalCount, StringFormat='📋 All ({0})'}"
                                Command="{Binding SetFilterCommand}" CommandParameter="All"
                                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                                TextColor="{AppThemeBinding Light=#333, Dark=#DDD}"
                                CornerRadius="6" FontSize="12" Padding="8,6" />
                        <Button Text="{Binding NeedsReviewCount, StringFormat='⚠️ Review ({0})'}"
                                Command="{Binding SetFilterCommand}" CommandParameter="NeedsReview"
                                BackgroundColor="#FFF3E0" TextColor="#E65100"
                                CornerRadius="6" FontSize="12" Padding="8,6" />
                        <Button Text="{Binding ApprovedCount, StringFormat='✅ Approved ({0})'}"
                                Command="{Binding SetFilterCommand}" CommandParameter="Approved"
                                BackgroundColor="#E8F5E9" TextColor="#2E7D32"
                                CornerRadius="6" FontSize="12" Padding="8,6" />
                        <Button Text="{Binding FailedCount, StringFormat='❌ Failed ({0})'}"
                                Command="{Binding SetFilterCommand}" CommandParameter="Failed"
                                BackgroundColor="#FFEBEE" TextColor="#C62828"
                                CornerRadius="6" FontSize="12" Padding="8,6" />
                    </VerticalStackLayout>
                </Border>

                <!-- Center: Stack Grid -->
                <CollectionView Grid.Column="1"
                                ItemsSource="{Binding FilteredStacks}"
                                SelectionMode="Single"
                                SelectedItem="{Binding SelectedStack, Mode=TwoWay}"
                                Margin="10">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="4"
                                         HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                            <Label Text="🔍" FontSize="36" HorizontalOptions="Center" />
                            <Label Text="No stacks match this filter"
                                   FontSize="16" TextColor="Gray" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:StackItemViewModel">
                            <Border Padding="6"
                                    StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}">
                                <VerticalStackLayout Spacing="4">
                                    <Image Source="{Binding ThumbnailSource}"
                                           HeightRequest="100" Aspect="AspectFill" />
                                    <Label Text="{Binding Id}" FontSize="11" FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="📸" IsVisible="{Binding HasBack}" FontSize="9" />
                                        <Label Text="{Binding StatusText}" FontSize="9"
                                               TextColor="{Binding StatusColor}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Right: Detail Panel -->
                <ScrollView Grid.Column="2"
                            IsVisible="{Binding HasSelectedStack}"
                            WidthRequest="360" Padding="15,10">
                    <VerticalStackLayout Spacing="12">

                        <!-- Front Image -->
                        <Border Padding="4" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}">
                            <Image Source="{Binding FrontImageSource}"
                                   HeightRequest="200" Aspect="AspectFit" />
                        </Border>

                        <!-- Back Image -->
                        <Border Padding="4" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}"
                                IsVisible="{Binding HasBackImage}">
                            <VerticalStackLayout>
                                <Label Text="📝 Back of Photo" FontSize="11"
                                       FontAttributes="Bold" Margin="4,0" />
                                <Image Source="{Binding BackImageSource}"
                                       HeightRequest="150" Aspect="AspectFit" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Analyze button (before AI analysis) -->
                        <Button Text="🤖 Analyze with AI"
                                Command="{Binding AnalyzeSelectedCommand}"
                                BackgroundColor="#6750A4" TextColor="White" CornerRadius="8"
                                IsVisible="{Binding HasAiResult, Converter={StaticResource InvertedBool}}" />

                        <!-- AI Results Section -->
                        <VerticalStackLayout Spacing="10" IsVisible="{Binding HasAiResult}">

                            <!-- Header + Confidence Badge -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="🤖 AI Analysis" FontSize="16" FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Border Grid.Column="1" Padding="10,4"
                                        StrokeShape="RoundRectangle 12,12,12,12" Stroke="Transparent"
                                        BackgroundColor="{Binding ConfidenceBadgeColor}">
                                    <Label Text="{Binding ConfidenceText}" TextColor="White"
                                           FontSize="12" FontAttributes="Bold" />
                                </Border>
                            </Grid>

                            <!-- Review Reason -->
                            <Label Text="{Binding ReviewReason}" FontSize="11" TextColor="Gray"
                                   FontAttributes="Italic" IsVisible="{Binding HasReviewReason}" />

                            <!-- Editable Fields -->
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Title" FontSize="11" FontAttributes="Bold" />
                                <Entry Text="{Binding EditTitle}" FontSize="13" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Description" FontSize="11" FontAttributes="Bold" />
                                <Editor Text="{Binding EditDescription}" HeightRequest="60" FontSize="13" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Date" FontSize="11" FontAttributes="Bold" />
                                <Entry Text="{Binding EditDate}" FontSize="13" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="People" FontSize="11" FontAttributes="Bold" />
                                <Entry Text="{Binding EditPeople}" FontSize="13"
                                       Placeholder="e.g., John, Jane" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Places" FontSize="11" FontAttributes="Bold" />
                                <Entry Text="{Binding EditPlaces}" FontSize="13" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Events" FontSize="11" FontAttributes="Bold" />
                                <Entry Text="{Binding EditEvents}" FontSize="13" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="OCR Text" FontSize="11" FontAttributes="Bold" />
                                <Editor Text="{Binding EditOcr}" HeightRequest="40"
                                        FontSize="13" IsReadOnly="True" />
                            </VerticalStackLayout>

                            <!-- Action Buttons -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                                <Button Text="✅ Approve"
                                        Command="{Binding ApproveCommand}"
                                        BackgroundColor="#388E3C" TextColor="White"
                                        CornerRadius="8" FontSize="13" />
                                <Button Grid.Column="1" Text="✏️ Save Edits"
                                        Command="{Binding ApproveWithEditsCommand}"
                                        BackgroundColor="#1565C0" TextColor="White"
                                        CornerRadius="8" FontSize="13" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Text="⏭ Skip"
                                        Command="{Binding SkipSelectedCommand}"
                                        BackgroundColor="#757575" TextColor="White"
                                        CornerRadius="8" FontSize="13" />
                                <Button Grid.Column="1" Text="🔄 Re-analyze"
                                        Command="{Binding AnalyzeSelectedCommand}"
                                        BackgroundColor="#6750A4" TextColor="White"
                                        CornerRadius="8" FontSize="13" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- EXIF Tags -->
                        <VerticalStackLayout Spacing="5" Margin="0,8,0,0">
                            <Label Text="📷 EXIF Tags" FontSize="14" FontAttributes="Bold" />
                            <CollectionView ItemsSource="{Binding ExifTags}" HeightRequest="150">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ExifTagItem">
                                        <Grid ColumnDefinitions="130,*" Padding="0,2">
                                            <Label Text="{Binding Key}" FontAttributes="Bold"
                                                   FontSize="11" />
                                            <Label Grid.Column="1" Text="{Binding Value}"
                                                   FontSize="11" TextColor="Gray" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

            </Grid>

            <!-- ── Progress Bar (during analysis) ── -->
            <Border Grid.Row="2" Padding="15,8" Stroke="Transparent"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                    IsVisible="{Binding IsAnalyzing}">
                <VerticalStackLayout Spacing="4">
                    <ProgressBar Progress="{Binding Progress}" ProgressColor="#6750A4"
                                 HeightRequest="6" />
                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Label Text="{Binding ProgressText}" FontSize="12" TextColor="Gray"
                               VerticalOptions="Center" />
                        <Button Text="Cancel" Command="{Binding CancelAnalysisCommand}"
                                FontSize="11" Padding="12,4" CornerRadius="4"
                                BackgroundColor="#B00020" TextColor="White" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </Grid>

    </Grid>

</ContentPage>
