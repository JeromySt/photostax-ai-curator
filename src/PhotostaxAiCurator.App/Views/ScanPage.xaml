<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhotostaxAiCurator.App.ViewModels"
             x:Class="PhotostaxAiCurator.App.Views.ScanPage"
             x:DataType="vm:ScanViewModel"
             Title="Scan Photos">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="15">

        <!-- Folder Selection -->
        <Frame Grid.Row="0" Padding="15" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D2D}" CornerRadius="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Entry Placeholder="Select photo folder..."
                       Text="{Binding FolderPath}"
                       IsReadOnly="True" />
                <Button Grid.Column="1"
                        Text="Browse..."
                        Command="{Binding BrowseFolderCommand}"
                        BackgroundColor="#6750A4"
                        TextColor="White" />
            </Grid>
        </Frame>

        <!-- Stats Bar -->
        <HorizontalStackLayout Grid.Row="1" Spacing="20" IsVisible="{Binding HasStacks}">
            <Label Text="{Binding TotalStacks, StringFormat='{0} stacks found'}"
                   FontSize="16" FontAttributes="Bold" />
            <Label Text="{Binding StacksWithBack, StringFormat='{0} with back scans'}"
                   FontSize="14" TextColor="Gray" />
        </HorizontalStackLayout>

        <!-- Photo Stacks Grid -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Stacks}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding StackSelectedCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="📷" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="No photos scanned yet" FontSize="18" HorizontalOptions="Center" TextColor="Gray" />
                    <Label Text="Select a folder to get started" FontSize="14" HorizontalOptions="Center" TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:StackItemViewModel">
                    <Frame Padding="8" CornerRadius="8" HasShadow="True">
                        <VerticalStackLayout Spacing="5">
                            <Image Source="{Binding ThumbnailSource}"
                                   HeightRequest="120"
                                   Aspect="AspectFill" />
                            <Label Text="{Binding Id}" FontSize="12" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="📸" IsVisible="{Binding HasBack}" FontSize="10" />
                                <Label Text="{Binding StatusText}" FontSize="10" TextColor="{Binding StatusColor}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
