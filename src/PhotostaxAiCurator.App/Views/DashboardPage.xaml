<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhotostaxAiCurator.App.ViewModels"
             x:Class="PhotostaxAiCurator.App.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <!-- Header -->
            <Label Text="AI Enrichment Dashboard" FontSize="28" FontAttributes="Bold" />

            <!-- Statistics Cards -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="15">
                <Border Grid.Column="0" Padding="15" BackgroundColor="#E8F5E9" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="{Binding TotalStacks}" FontSize="32" FontAttributes="Bold" TextColor="#2E7D32" />
                        <Label Text="Total Stacks" FontSize="12" TextColor="#388E3C" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Padding="15" BackgroundColor="#E3F2FD" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="{Binding Analyzed}" FontSize="32" FontAttributes="Bold" TextColor="#1565C0" />
                        <Label Text="Analyzed" FontSize="12" TextColor="#1976D2" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" Padding="15" BackgroundColor="#FFF3E0" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="{Binding NeedsReview}" FontSize="32" FontAttributes="Bold" TextColor="#E65100" />
                        <Label Text="Needs Review" FontSize="12" TextColor="#EF6C00" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="3" Padding="15" BackgroundColor="#F3E5F5" StrokeShape="RoundRectangle 8,8,8,8" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="{Binding Written}" FontSize="32" FontAttributes="Bold" TextColor="#6A1B9A" />
                        <Label Text="Written" FontSize="12" TextColor="#7B1FA2" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Progress -->
            <ProgressBar Progress="{Binding OverallProgress}" ProgressColor="#6750A4" HeightRequest="8" />
            <Label Text="{Binding ProgressText}" FontSize="14" TextColor="Gray" HorizontalOptions="Center" />

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">
                <Button Grid.Column="0"
                        Text="🤖 Start AI Analysis"
                        Command="{Binding StartAnalysisCommand}"
                        BackgroundColor="#6750A4" TextColor="White"
                        FontSize="16" HeightRequest="50" CornerRadius="8" />
                <Button Grid.Column="1"
                        Text="📋 Review Queue ({Binding NeedsReview})"
                        Command="{Binding GoToReviewCommand}"
                        BackgroundColor="#625B71" TextColor="White"
                        FontSize="16" HeightRequest="50" CornerRadius="8" />
                <Button Grid.Column="2"
                        Text="✅ Write All Approved"
                        Command="{Binding WriteAllApprovedCommand}"
                        BackgroundColor="#7D5260" TextColor="White"
                        FontSize="16" HeightRequest="50" CornerRadius="8" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>