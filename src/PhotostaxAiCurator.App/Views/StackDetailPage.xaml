<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhotostaxAiCurator.App.ViewModels"
             x:Class="PhotostaxAiCurator.App.Views.StackDetailPage"
             x:DataType="vm:StackDetailViewModel"
             Title="{Binding StackId}">

    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="15">

        <!-- Images Row -->
        <ScrollView Grid.Row="0" Orientation="Horizontal" HeightRequest="250">
            <HorizontalStackLayout Spacing="15">
                <Frame Padding="5" CornerRadius="8" IsVisible="{Binding HasOriginal}">
                    <VerticalStackLayout>
                        <Label Text="Original" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Image Source="{Binding OriginalImageSource}" HeightRequest="200" Aspect="AspectFit" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Padding="5" CornerRadius="8" IsVisible="{Binding HasEnhanced}">
                    <VerticalStackLayout>
                        <Label Text="Enhanced" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Image Source="{Binding EnhancedImageSource}" HeightRequest="200" Aspect="AspectFit" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Padding="5" CornerRadius="8" IsVisible="{Binding HasBack}">
                    <VerticalStackLayout>
                        <Label Text="Back" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Image Source="{Binding BackImageSource}" HeightRequest="200" Aspect="AspectFit" />
                    </VerticalStackLayout>
                </Frame>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Metadata -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="10">
                <Label Text="Metadata" FontSize="20" FontAttributes="Bold" />

                <!-- AI Analysis (if available) -->
                <Frame Padding="15" CornerRadius="8" IsVisible="{Binding HasAiResult}"
                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D2D}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🤖 AI Analysis" FontSize="16" FontAttributes="Bold" />
                        <Label Text="{Binding AiTitle, StringFormat='Title: {0}'}" />
                        <Label Text="{Binding AiDescription, StringFormat='Description: {0}'}" />
                        <Label Text="{Binding AiDate, StringFormat='Date: {0}'}" />
                        <Label Text="{Binding AiPeople, StringFormat='People: {0}'}" />
                        <Label Text="{Binding AiPlaces, StringFormat='Places: {0}'}" />
                        <Label Text="{Binding AiEvents, StringFormat='Events: {0}'}" />
                        <Label Text="{Binding AiOcrBack, StringFormat='OCR (Back): {0}'}" />
                        <Label Text="{Binding AiMood, StringFormat='Mood: {0}'}" />
                        <Label Text="{Binding AiConfidence, StringFormat='Confidence: {0:P0}'}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- EXIF Tags -->
                <Frame Padding="15" CornerRadius="8" BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1E1E1E}">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="📷 EXIF Tags" FontSize="16" FontAttributes="Bold" />
                        <CollectionView ItemsSource="{Binding ExifTags}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="150,*" Padding="0,2">
                                        <Label Text="{Binding Key}" FontAttributes="Bold" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding Value}" FontSize="12" TextColor="Gray" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Analyze Button -->
                <Button Text="🤖 Analyze with AI"
                        Command="{Binding AnalyzeCommand}"
                        BackgroundColor="#6750A4" TextColor="White"
                        CornerRadius="8" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
