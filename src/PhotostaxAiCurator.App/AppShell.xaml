<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PhotostaxAiCurator.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PhotostaxAiCurator.App.Views"
    Title="PhotoStax AI Curator"
    Shell.FlyoutBehavior="Flyout">

    <FlyoutItem Title="Scan">
        <ShellContent
            Title="Scan Photos"
            ContentTemplate="{DataTemplate views:ScanPage}"
            Route="ScanPage" />
    </FlyoutItem>

    <FlyoutItem Title="Dashboard">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="DashboardPage" />
    </FlyoutItem>

    <FlyoutItem Title="Review">
        <ShellContent
            Title="Review Queue"
            ContentTemplate="{DataTemplate views:ReviewPage}"
            Route="ReviewPage" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </FlyoutItem>

</Shell>
